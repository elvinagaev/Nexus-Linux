#!/bin/sh
set -e

# --mode debian and the explicit mirror/keyring options below are required
# because Ubuntu's packaged live-build ships /etc/live/build.conf system
# defaults that point at archive.ubuntu.com (mode=ubuntu) -- and Ubuntu's
# archive has no "trixie" suite (that's a Debian-only codename), so
# debootstrap fails with "Failed getting release file" unless we override
# these explicitly here, regardless of which host/runner builds the image.
#
# --security false: Ubuntu's packaged live-build (3.0~a57, a very old
# snapshot) predates Debian's 2023 security-suite rename. It writes the
# pre-bookworm "trixie/updates" security line, but security.debian.org
# only serves "trixie-security" for Debian 12+, so apt-get update inside
# the chroot 404s and aborts the build. Disabling the security repo here
# avoids that; a hooks.chroot script can re-add the correct
# "trixie-security" line later if security updates are needed at build time.
lb config noauto \
    --mode debian \
    --distribution trixie \
    --archive-areas "main contrib non-free-firmware" \
    --architectures amd64 \
    --binary-images iso-hybrid \
    --linux-packages linux-image \
    --mirror-bootstrap "http://deb.debian.org/debian/" \
    --mirror-chroot "http://deb.debian.org/debian/" \
    --mirror-binary "http://deb.debian.org/debian/" \
    --security false \
    --keyring-packages "debian-archive-keyring" \
    --bootappend-live "boot=live components quiet splash username=nexus hostname=nexus-linux" \
    "${@}"

