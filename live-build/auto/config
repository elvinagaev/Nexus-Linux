#!/bin/sh
set -e

# --mode debian and the explicit mirror/keyring options below are required
# because Ubuntu's packaged live-build ships /etc/live/build.conf system
# defaults that point at archive.ubuntu.com (mode=ubuntu) -- and Ubuntu's
# archive has no "trixie" suite (that's a Debian-only codename), so
# debootstrap fails with "Failed getting release file" unless we override
# these explicitly here, regardless of which host/runner builds the image.
#
# Security repo: Ubuntu's packaged live-build (3.0~a57, a very old
# snapshot) predates Debian's 2023 security-suite rename. It writes the
# pre-bookworm "trixie/updates" security line, but security.debian.org
# only serves "trixie-security" for Debian 12+, so apt-get update inside
# the chroot 404s and aborts the build. `--security false` alone did NOT
# suppress this line on this old version (tested, still failed), so the
# mirror URLs are explicitly blanked out here instead -- an empty mirror
# means live-build has nothing to build the "deb ... /updates ..." line
# from, so it is skipped entirely. The correct "trixie-security" line is
# re-added for the final image via
# config/hooks/live/0100-add-security-repo.hook.chroot.
#
# NOTE: mirror URLs below deliberately have NO trailing slash. With a
# trailing slash (which matches live-build's own documented default,
# "http://deb.debian.org/debian/"), lb_chroot_linux-image builds a
# double-slash URL ("debian//dists/trixie/Contents-amd64.gz") when looking
# up the kernel package name -- Debian's Fastly-backed mirror does not
# normalize that and returns 404, aborting the build. Dropping the
# trailing slash avoids the double slash entirely.
lb config noauto \
    --mode debian \
    --distribution trixie \
    --archive-areas "main contrib non-free-firmware" \
    --architectures amd64 \
    --binary-images iso-hybrid \
    --linux-packages linux-image \
    --mirror-bootstrap "http://deb.debian.org/debian" \
    --mirror-chroot "http://deb.debian.org/debian" \
    --mirror-binary "http://deb.debian.org/debian" \
    --security false \
    --mirror-chroot-security "" \
    --mirror-binary-security "" \
    --keyring-packages "debian-archive-keyring" \
    --bootappend-live "boot=live components quiet splash username=nexus hostname=nexus-linux" \
    "${@}"

